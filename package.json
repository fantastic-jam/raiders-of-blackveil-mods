{
  "name": "raiders-of-blackveil-mods",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "node --experimental-strip-types tools/build.mts",
    "build:debug": "node --experimental-strip-types tools/build.mts --debug",
    "deploy": "node --experimental-strip-types tools/deploy.mts",
    "deploy:debug": "node --experimental-strip-types tools/deploy.mts --debug",
    "package": "node --experimental-strip-types tools/package.mts",
    "release": "node --experimental-strip-types tools/release.mts",
    "setup": "node --experimental-strip-types tools/setup.mts",
    "start": "node --experimental-strip-types tools/start.mts",
    "unreleased": "node --experimental-strip-types tools/unreleased.mts",
    "typecheck": "tsgo --project tools/tsconfig.json --noEmit",
    "lint": "eslint --config tools/eslint.config.mts tools/",
    "lint:fix": "eslint --config tools/eslint.config.mts tools/ --fix",
    "lint:cs": "dotnet format mods/ --verify-no-changes",
    "lint:cs:fix": "dotnet format mods/",
    "lint:all": "pnpm run lint && pnpm run lint:cs && pnpm run typecheck",
    "format": "prettier --write tools/",
    "format:check": "prettier --check tools/",
    "clean": "node --experimental-strip-types tools/clean.mts",
    "prepare": "husky",
    "pre-release": "node --experimental-strip-types tools/pre-release.mts",
    "init-changelogs": "node --experimental-strip-types tools/init-changelogs.mts"
  },
  "fchange": {
    "folders": [
      "mods",
      "libs"
    ],
    "types": [
      "fix",
      "new",
      "chore",
      "tidy"
    ],
    "scopes": [
      "Repo",
      "All"
    ],
    "commitFormat": "{type}({pkg}): {message}"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@fantastic-jam/fchange": "latest",
    "@octokit/rest": "latest",
    "@types/archiver": "latest",
    "@types/fs-extra": "latest",
    "@types/node": "latest",
    "@types/semver": "latest",
    "@types/unzipper": "latest",
    "@typescript/native-preview": "latest",
    "archiver": "latest",
    "dotenv": "latest",
    "eslint": "latest",
    "eslint-config-prettier": "latest",
    "fs-extra": "latest",
    "glob": "latest",
    "husky": "latest",
    "jiti": "latest",
    "prettier": "latest",
    "semver": "latest",
    "typescript-eslint": "latest",
    "unzipper": "latest"
  }
}
